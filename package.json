{
  "name": "orgloop-monorepo",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "clean": "turbo run clean",
    "typecheck": "turbo run typecheck",
    "release": "bash scripts/release.sh",
    "release:dry": "bash scripts/release.sh --dry-run"
  },
  "pnpm": {
    "overrides": {
      "vite": ">=7.3.2",
      "picomatch": ">=4.0.4",
      "rollup": ">=4.59.0",
      "protobufjs": ">=7.5.5"
    }
  },
  "devDependencies": {
    "@biomejs/biome": "~2.4.15",
    "@types/node": "~25.6.2",
    "turbo": "~2.9.12",
    "typescript": "~6.0.3",
    "vitest": "~4.1.5"
  },
  "dependencies": {
    "@orgloop/transform-agent-gate": "workspace:^"
  },
  "version": "0.7.8"
}
